# =============================================================================
# Adeel IT Solutions Platform — Environment Variables (Stage 5 §16)
# Copy to `.env` for local development. NEVER commit real secrets.
# Secrets belong in the Vercel/CI secret manager in deployed environments.
# =============================================================================

# --- Runtime ---
NODE_ENV=development

# --- Database (Neon PostgreSQL) ---
# DATABASE_URL uses the pooled connection for the app; DIRECT_URL is unpooled for migrations.
DATABASE_URL="postgresql://user:password@ep-pooler.neon.tech/adeelit?sslmode=require"
DIRECT_URL="postgresql://user:password@ep.neon.tech/adeelit?sslmode=require"

# --- Auth.js ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-32+-character-random-secret"

# --- Cloudinary (media) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- Resend (transactional email) ---
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="Adeel IT Solutions <noreply@adeelit.example>"

# --- Upstash Redis (rate limiting, caching, locks) ---
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# --- Trigger.dev (background jobs) ---
TRIGGER_SECRET_KEY="tr_dev_your_key"
TRIGGER_PROJECT_ID="proj_your_project_id"

# --- OpenTelemetry (optional; tracing disabled if endpoint unset) ---
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_SERVICE_NAME="adeel-it-platform"

# --- Operational flags ---
MAINTENANCE_MODE="false"

# --- Public (inlined into the client bundle; must be safe to expose) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_GTM_ID=""

# --- Seed (local development only) ---
SEED_ADMIN_EMAIL="admin@adeelit.local"
SEED_ADMIN_PASSWORD="ChangeMe!Local123"
