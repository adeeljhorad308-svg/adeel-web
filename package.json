{
  "name": "adeel-it-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Adeel IT Solutions — premium international software agency platform. Modular monolith on Next.js 15.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "trigger:dev": "trigger.dev@latest dev",
    "prepare": "husky || true",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.55.0",
    "@opentelemetry/resources": "1.28.0",
    "@opentelemetry/sdk-node": "0.55.0",
    "@opentelemetry/semantic-conventions": "1.28.0",
    "@prisma/client": "5.22.0",
    "@trigger.dev/sdk": "3.3.1",
    "@upstash/ratelimit": "2.0.5",
    "@upstash/redis": "1.34.3",
    "argon2": "0.41.1",
    "cloudinary": "2.5.1",
    "clsx": "2.1.1",
    "isomorphic-dompurify": "2.19.0",
    "lucide-react": "0.460.0",
    "next": "15.1.11",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "3.26.3",
    "pino": "9.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.2",
    "@hookform/resolvers": "3.9.1",
    "resend": "4.0.1",
    "server-only": "0.0.1",
    "tailwind-merge": "2.5.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.17.0",
    "@playwright/test": "1.49.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "axe-core": "4.10.2",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.9",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "jsdom": "25.0.1",
    "lint-staged": "15.2.11",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1",
    "vitest": "2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
